{
  "name": "debo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run dev:website",
    "cli": "bun run --filter @debo.life/cli start",
    "dev:landing": "bun run --filter '@debo/landing-page' dev",
    "dev:website": "bun run --filter '@debo/website' dev",
    "dev:voice": "bun run --filter '@debo/voice-agent' dev",
    "dev:web": "bun run dev:landing",
    "dev:app": "bun run dev:website",
    "build": "bun run build:packages && (if [ \"$VERCEL\" = \"1\" ]; then bun run build:website; else bun run build:landing && bun run build:website && bun run build:voice; fi)",
    "build:packages": "bun run --filter './packages/*' build",
    "build:landing": "bun run --filter '@debo/landing-page' build",
    "build:website": "bun run --filter '@debo/website' build",
    "build:voice": "bun run --filter '@debo/voice-agent' build",
    "build:web": "bun run build:landing",
    "build:app": "bun run build:website",
    "deploy": "bun scripts/deploy-all.mjs",
    "deploy:landing": "bun run --filter '@debo/landing-page' deploy",
    "deploy:website": "bun scripts/deploy-vercel-website.mjs",
    "deploy:web": "bun run deploy:landing",
    "deploy:app": "bun run deploy:website",
    "deploy:all": "bun scripts/deploy-all.mjs",
    "db:push": "bun run --filter '@debo/db' db:push",
    "typecheck": "bun run --filter './packages/*' typecheck && bun run --filter '@debo/landing-page' typecheck && bun run --filter '@debo/website' typecheck && bun run --filter '@debo/mcp' typecheck && bun run --filter '@debo/voice-agent' typecheck && bun run --filter '@debo.life/cli' typecheck",
    "cf-typegen": "bun run --filter '@debo/landing-page' cf-typegen"
  },
  "devDependencies": {
    "@opennextjs/aws": "^3.10.4",
    "@opennextjs/cloudflare": "1.19.6",
    "@types/node": "^25.6.0",
    "typescript": "^5.7.4",
    "vercel": "^50.26.1",
    "wrangler": "^4.87.0"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
