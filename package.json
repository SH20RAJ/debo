{
  "name": "debo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '@debo/app' dev",
    "dev:web": "bun run --filter '@debo/web' dev",
    "dev:app": "bun run --filter '@debo/app' dev",
    "build": "bun run build:packages && bun run build:web && bun run build:app",
    "build:packages": "bun run --filter './packages/*' build",
    "build:web": "bun run --filter '@debo/web' build",
    "build:app": "bun run --filter '@debo/app' build",
    "deploy": "bun scripts/deploy-all.mjs",
    "deploy:web": "bun run --filter '@debo/web' deploy",
    "deploy:app": "bun run --filter '@debo/app' deploy",
    "deploy:all": "bun scripts/deploy-all.mjs",
    "db:push": "bun run --filter '@debo/db' db:push",
    "typecheck": "bun run --filter './packages/*' typecheck && bun run --filter './apps/*' typecheck",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts"
  },
  "devDependencies": {
    "@opennextjs/aws": "^3.10.4",
    "@opennextjs/cloudflare": "1.19.6",
    "typescript": "^5.7.4",
    "wrangler": "^4.87.0"
  }
}
