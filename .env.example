# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:3001

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# ─── AI Providers (OpenAI-compatible) ─────────────────────────────────────────
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=meta/llama-3.3-70b-instruct
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
NVIDIA_API_KEY=

# ─── Qdrant (Vector DB) ──────────────────────────────────────────────────────
QDRANT_URL=https://your-cluster.qdrant.io:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=debo_journals

# ─── Cloudflare R2 (Media Storage) ───────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=debo-media
R2_PUBLIC_BASE_URL=

# ─── Agents Service (Internal AI Service) ────────────────────────────────────
AGENTS_SERVICE_URL=http://localhost:3002
AGENTS_INTERNAL_SECRET=change-me-to-a-random-secret

# ─── LiveKit (Voice) ─────────────────────────────────────────────────────────
NEXT_PUBLIC_LIVEKIT_URL=wss://your-livekit-url.cloud
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ─── Stack Auth ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_STACK_PROJECT_ID=
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=
STACK_SECRET_SERVER_KEY=

# ─── Connectors ───────────────────────────────────────────────────────────────
COMPOSIO_API_KEY=
# Nango (Phase 5.2 — placeholder)
NEXT_PUBLIC_NANGO_PUBLIC_KEY=
NANGO_SECRET_KEY=

# ─── Mem0 (Personalization Memory — optional) ────────────────────────────────
MEM0_API_KEY=
