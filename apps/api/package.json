{
  "name": "@debo/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch --env-file=../../.env.local --env-file=.env.local src/index.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "seed": "tsx src/scripts/seed.ts"
  },
  "dependencies": {
    "@debo/db": "workspace:*",
    "@debo/memory": "workspace:*",
    "@debo/storage": "workspace:*",
    "@debo/types": "workspace:*",
    "dotenv": "^16.4.7",
    "hono": "^4.7.10",
    "livekit-server-sdk": "^2.13.3",
    "nanoid": "^5.1.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@hono/node-server": "^1.13.8",
    "@types/bun": "^1.2.0",
    "@types/node": "^25.6.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.7.4"
  }
}
